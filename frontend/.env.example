VITE_BACKEND_URL=http://localhost:5000/api

# Google OAuth (login con Google)
# El mismo valor del Client ID también va en el .env del FRONTEND como VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com

# Pexels — fotos de stock de vehículos (gratis en pexels.com/api)
VITE_PEXELS_API_KEY=tu_api_key_de_pexels

# logo.dev — logos de marcas de vehículos (gratis en logo.dev, opcional pero recomendado)
VITE_LOGO_DEV_TOKEN=tu_token_de_logo_dev
