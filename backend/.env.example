# URLs
# IMPORTANTE: URL_FRONTEND NO debe tener barra al final (el navegador envía el origin sin barra)
# Desarrollo:  http://localhost:5173
# Producción:  https://tu-dominio-frontend.vercel.app
URL_FRONTEND=http://localhost:5173
URL_BACKEND=http://localhost:5000/api/


# Admin seed
ADMIN_EMAIL=admin@autoreporta.ec
ADMIN_PASSWORD=CambiaEstaClave123
ADMIN_NOMBRE=Administrador

# Cloudinary (para subir imágenes y documentos)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Google OAuth (login con Google)
# El mismo valor del Client ID también va en el .env del FRONTEND como VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com


ADMIN_CORREO_CONTACTO=elcorreodondeQuieresRecibirMensajes@gmail.com

